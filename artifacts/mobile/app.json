{
  "expo": {
    "name": "Word Hunt",
    "slug": "word-hunt-iq",
    "version": "1.0.1",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/Images/icon.png",
    "scheme": "wordhunt",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0218"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wordhunt.game",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.jalaltech.wordhuntiq",
      "versionCode": 2,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/Images/icon.png",
        "backgroundColor": "#0a0218"
      },
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.INTERNET"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/Images/icon.png",
      "bundler": "metro",
      "description": "Word Hunt — find hidden words, build your streak, and challenge yourself daily in this fast-paced word puzzle game."
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.24"
          }
        }
      ],
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4356067796830671~9507716748"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0218",
          "image": "./assets/Images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "8efad970-d4ce-41fa-8913-096c2979ce27"
      }
    }
  }
}
