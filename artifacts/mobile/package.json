{
  "name": "@workspace/mobile",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@10.2.4",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID npx expo start --tunnel --web --port $PORT",
    "tunnel": "npx expo start --tunnel",
    "build": "npx expo export --platform web --output-dir dist",
    "serve": "node server/serve.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo/cli": "^0.18.0",
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@tanstack/react-query": "^5.50.21",
    "@types/react": "~18.2.0",
    "@ungap/structured-clone": "^1.3.0",
    "expo": "~51.0.0",
    "expo-av": "~14.0.0",
    "expo-blur": "~13.0.0",
    "expo-constants": "~16.0.0",
    "expo-font": "~12.0.0",
    "expo-haptics": "~13.0.0",
    "expo-image": "~1.13.0",
    "expo-image-picker": "~15.0.7",
    "expo-linear-gradient": "~13.0.0",
    "expo-linking": "~6.3.0",
    "expo-location": "~17.0.0",
    "expo-router": "~3.5.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.0",
    "expo-system-ui": "~3.0.0",
    "expo-web-browser": "~13.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "~4.10.0",
    "react-native-screens": "~3.31.0",
    "react-native-svg": "^15.2.0",
    "react-native-web": "~0.19.0",
    "react-native-google-mobile-ads": "^11.0.0",
    "typescript": "~5.3.0",
    "zod": "^3.25.7",
    "zod-validation-error": "^3.4.0"
  },
  "dependencies": {}
}
